#include<stdio.h>

int main()
{
    int terms, first = 0, second = 1, next;

    printf("Enter number of terms: ");
    scanf("%d",&terms);

    for(int i = 0; i < terms; i++)
    {
        printf("%d ", first);
        next = first + second;
        first = second;
        second = next;
    }

    return 0;
}
#include<stdio.h>

int main()
{
    int n, a = 0, b = 1, fib;

    printf("Enter position: ");
    scanf("%d",&n);

    if(n == 1)
        fib = a;
    else if(n == 2)
        fib = b;
    else
    {
        for(int i = 3; i <= n; i++)
        {
            fib = a + b;
            a = b;
            b = fib;
        }
    }

    printf("Fibonacci term = %d", fib);

    return 0;
}
#include<stdio.h>

int main()
{
    int num, original, digit, total = 0;

    printf("Enter number: ");
    scanf("%d",&num);

    original = num;

    while(num != 0)
    {
        digit = num % 10;
        total = total + digit * digit * digit;
        num = num / 10;
    }

    if(total == original)
        printf("Armstrong Number");
    else
        printf("Not Armstrong Number");

    return 0;
}
#include<stdio.h>

int main()
{
    int start, end;

    printf("Enter range: ");
    scanf("%d%d",&start,&end);

    for(int i = start; i <= end; i++)
    {
        int temp = i, digit, sum = 0;

        while(temp > 0)
        {
            digit = temp % 10;
            sum += digit * digit * digit;
            temp /= 10;
        }

        if(sum == i)
            printf("%d ", i);
    }

    return 0;
}